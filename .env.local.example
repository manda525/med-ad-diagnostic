# Stripe (test mode keys — get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Price IDs (filled after running: node scripts/setup-stripe-products.mjs)
STRIPE_PRICE_INDIVIDUAL=price_xxx
STRIPE_PRICE_CORPORATE=price_xxx

# Webhook signing secret (Stripe Dashboard → Developers → Webhooks → your endpoint)
STRIPE_WEBHOOK_SECRET=whsec_xxx
